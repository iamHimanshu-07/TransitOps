# Server
PORT=3000
NODE_ENV=production

# Auth — REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# SQLite location. On Render, must point to a persistent disk mount (e.g. /data).
# Leave blank locally to use ./transitops.db in the project root.
DATA_DIR=
