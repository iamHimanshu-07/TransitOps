# Server
PORT=3000
NODE_ENV=production

# Auth — REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Database
# Leave DATABASE_URL blank locally — uses ./transitops.db (SQLite).
# On Render, this is auto-injected from the linked database in render.yaml.
# For manual Postgres testing: postgresql://user:pass@host:5432/dbname
DATABASE_URL=
